# === Email delivery (Gmail SMTP) ===
# IMPORTANT: Gmail requires a 16-character App Password, NOT your normal
# account password. Enable 2-Step Verification, then create one at:
#   https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=angli.claude@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_FROM=angli.claude@gmail.com
EMAIL_TO=angli1937@gmail.com

# === Instruments ===
EQUITY_TICKERS=SPY,QQQ
VOL_TICKERS=^VIX,^VXN
SMA_PERIODS=5,10,50,200

# === Schedule / monitoring (Pacific time) ===
# Baseline push at market open (ET 9:30 = PT 6:30). Monitor every N minutes
# during market hours; alert when any instrument moves > threshold % vs baseline.
MONITOR_TZ=America/Los_Angeles
BASELINE_HOUR=6
BASELINE_MINUTE=30
REFRESH_MINUTES=5
# Default threshold for instruments without a per-symbol override (the equities).
ALERT_THRESHOLD_PCT=1.0
# Per-symbol overrides (SYM:pct,...). Equities: ~1% = a real day. Volatility
# indices swing ~5%/day, so 1% is noise. VIX/VXN tiers:
#   5 = sensitive (chatty) · 10 = balanced (recommended) · 15 = only big spikes
ALERT_THRESHOLDS=^VIX:10,^VXN:10

# === Data / state ===
HISTORY_PERIOD=2y
# Local JSON file by default. On Cloud Run use a GCS object instead, e.g.
#   STATE_PATH=gs://your-bucket/state.json
STATE_PATH=monitor_state.json
