# === Required: Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Market Data (optional — falls back to yfinance) ===
FMP_API_KEY=your_fmp_api_key

# === News (optional — falls back to Google News RSS) ===
MARKETAUX_API_KEY=your_marketaux_api_key

# === LLM Analysis (at least one recommended; falls back to template summary) ===
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# === Watchlist (optional, comma-separated, max 10) ===
WATCHLIST=NVDA,AAPL,TSLA

# === Deep Analysis via TradingAgents (optional) ===
DEEP_ANALYSIS_ENABLED=false
DEEP_ANALYSIS_MAX_TICKERS=3
DEEP_ANALYSIS_TIMEOUT=300

# === Provider Adapter Layer (Phase 0) ===
# Alpaca Markets — real-time IEX quotes + Benzinga news (free tier)
# Sign up: https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Finnhub — fundamentals, earnings, analyst ratings, company news (free tier)
# Sign up: https://finnhub.io
FINNHUB_API_KEY=

# FRED — macroeconomic indicators, yield curve (free)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# yfinance needs no API key

# Top movers filter thresholds
MOVER_MIN_MARKET_CAP_B=10.0
MOVER_MIN_VOLUME=10000000
