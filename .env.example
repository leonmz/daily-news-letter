# === Required: Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Market Data (optional — falls back to yfinance) ===
FMP_API_KEY=your_fmp_api_key

# === News (optional — falls back to Google News RSS) ===
MARKETAUX_API_KEY=your_marketaux_api_key

# === LLM Analysis (at least one recommended; falls back to template summary) ===
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# === Watchlist (optional, comma-separated, max 10) ===
WATCHLIST=NVDA,AAPL,TSLA

# === Deep Analysis via TradingAgents (optional) ===
DEEP_ANALYSIS_ENABLED=false
DEEP_ANALYSIS_MAX_TICKERS=3
DEEP_ANALYSIS_TIMEOUT=300
